  "triggers": ["proposal", "rfp", "rfq", "scope of work", "sow", "engagement", "bid", "vendor proposal"],
  "default_sitemap": [
    { "slug": "cover",            "role": "title-page+client-info" },
    { "slug": "executive-summary","role": "high-level-overview" },
    { "slug": "problem",          "role": "client-challenge-statement" },
    { "slug": "solution",         "role": "approach+methodology" },
    { "slug": "scope",            "role": "deliverables+exclusions" },
    { "slug": "timeline",         "role": "milestone-schedule" },
    { "slug": "investment",       "role": "pricing+payment-terms" },
    { "slug": "team",             "role": "key-personnel-bios" },
    { "slug": "next-steps",       "role": "signature-page" }
  ],
  "compliance_blocks": ["confidentiality-notice", "validity-period-disclaimer", "terms-of-engagement-reference"],
