  "schema_org_primary": "Course",
  "voice_template": "instructive and encouraging, expert-led, focuses on transformation and concrete outcomes",
  "palettes": [
    { "name": "academic-navy",   "hexes": ["#1E3A8A", "#FBBF24", "#FFFFFF", "#0F172A"] },
    { "name": "creator-violet",  "hexes": ["#7C3AED", "#FFFFFF", "#EDE9FE", "#1E1B4B"] },
    { "name": "edu-emerald",     "hexes": ["#059669", "#F0FDF4", "#FBBF24", "#022C22"] },
    { "name": "professional",    "hexes": ["#0F172A", "#F97316", "#F8FAFC", "#FAFAFA"] },
    { "name": "warm-classroom",  "hexes": ["#B45309", "#FFFCF5", "#FEF3C7", "#1F1812"] }
  ],
  "section_library": ["hero-course-promise", "instructor-card", "video-trailer", "what-you-learn", "curriculum-modules", "outcome-stats", "testimonial-grid", "pricing-tiers", "bonus-stack", "guarantee-badge", "faq", "enroll-cta", "footer"],
