    { "slug": "hook",         "role": "memorable-melodic-phrase" },
    { "slug": "verse",        "role": "brand-message+vocal" },
    { "slug": "tagline",      "role": "spoken-or-sung-slogan" },
    { "slug": "logo-stinger", "role": "brand-mnemonic-end" }
