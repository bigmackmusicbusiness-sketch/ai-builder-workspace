    { "name": "playful-teal",     "hexes": ["#14B8A6", "#FFFFFF", "#CCFBF1", "#134E4A"] },
    { "name": "bold-cobalt",      "hexes": ["#1D4ED8", "#FFFFFF", "#DBEAFE", "#172554"] }
  ],
  "section_library": ["earworm-hook", "bouncy-bassline", "vocal-melody", "harmony-vox", "tagline-line", "logo-stinger-end", "smile-fx"],
  "image_directives": "vibrant flat illustration; cheerful brand imagery; clean typography; high-energy color blocking",
