{
  "niche": "home-services-contractor",
  "label": "Home Services Contractor",
  "triggers": ["contractor", "plumber", "electrician", "hvac", "roofing", "remodel", "handyman", "landscaping", "general contractor", "home services"],
  "default_sitemap": [
    { "slug": "index",        "role": "hero+services-preview+phone-cta" },
    { "slug": "services",     "role": "service-list" },
    { "slug": "service-area", "role": "coverage-map" },
    { "slug": "projects",     "role": "before-after-gallery" },
    { "slug": "reviews",      "role": "testimonials" },
    { "slug": "about",        "role": "company-story+licenses" },
    { "slug": "contact",      "role": "estimate-form+phone+hours" }
  ],
  "compliance_blocks": ["license-bond-insurance-footer", "warranty-disclosure", "epa-lead-rrp-notice", "ada-accessibility-statement"],
  "schema_org_primary": "HomeAndConstructionBusiness",
  "voice_template": "straightforward, neighborly, no-nonsense, emphasizes reliability and showing up on time",
  "palettes": [
    { "name": "trade-blue",     "hexes": ["#1E40AF", "#F59E0B", "#FFFFFF", "#0F172A"] },
    { "name": "work-red",       "hexes": ["#B91C1C", "#1F2937", "#F3F4F6", "#FFFFFF"] },
    { "name": "field-green",    "hexes": ["#166534", "#FBBF24", "#F5F5F4", "#0A1F12"] },
    { "name": "iron-orange",    "hexes": ["#EA580C", "#0F172A", "#FAFAFA", "#1F1812"] },
    { "name": "steel-yellow",   "hexes": ["#475569", "#FACC15", "#F8FAFC", "#0F172A"] },
    { "name": "classic-navy",   "hexes": ["#1E3A8A", "#FFFFFF", "#DBEAFE", "#0A0A0A"] }
  ],
  "section_library": ["hero", "page-hero", "phone-cta-bar", "services-grid", "service-detail", "service-area-map", "before-after-gallery", "testimonial-card", "review-strip", "license-badge-strip", "estimate-form", "hours-strip", "address-card", "footer"],
  "image_directives": "real job-site photography. Crews in branded uniforms, trucks, finished installations, before-and-after shots. Show licensing, badges, and real customers. Avoid stock-photo workers in pristine outfits. Mud, tools, and pride of work over polished marketing imagery.",
  "voice_pet_words": ["licensed", "insured", "on-time", "guaranteed", "local", "honest", "quote"],
  "primary_keywords": ["home services", "contractor", "free estimate", "local pros"]
}
