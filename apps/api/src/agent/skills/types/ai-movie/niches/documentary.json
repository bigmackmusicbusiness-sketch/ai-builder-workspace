  "section_library": ["cold-open-hook", "title-card", "establishing-shot", "lower-third-name-title", "interview-A-roll", "B-roll-sequence", "archival-photo-zoom", "archival-footage-clip", "map-graphic", "data-visualization", "narration-voice-over", "ambient-sync-sound", "transition-fade", "act-break-card", "credits-roll", "fact-check-overlay"],
  "image_directives": "naturalistic cinematography. Available light, handheld where appropriate, observational compositions. Archival materials should be color-graded for cohesion. Avoid glossy commercial looks. Restrained color, real textures, real grain when appropriate.",
