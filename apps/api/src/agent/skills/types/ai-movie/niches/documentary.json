    { "name": "investigative-noir","hexes": ["#0F172A", "#94A3B8", "#1E293B", "#F8FAFC"] },
    { "name": "naturalistic-earth","hexes": ["#57534E", "#F5F5F4", "#A8A29E", "#1C1917"] },
