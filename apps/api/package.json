{
  "name": "@abw/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit && node build.mjs",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --dir tests/integration"
  },
  "dependencies": {
    "@abw/agent-core": "workspace:*",
    "@abw/db": "workspace:*",
    "@abw/providers": "workspace:*",
    "@abw/security": "workspace:*",
    "@abw/shared": "workspace:*",
    "@abw/verify": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/sensible": "^5.6.0",
    "@supabase/supabase-js": "^2.103.3",
    "drizzle-orm": "^0.31.0",
    "esbuild": "^0.21.5",
    "fastify": "^4.27.0",
    "libsodium-wrappers": "^0.7.16",
    "pino": "^9.1.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^20.12.12",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
