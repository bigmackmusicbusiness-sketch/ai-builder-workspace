{
  "name": "@abw/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit && node build.mjs",
    "start": "node --env-file=.env dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --dir tests/integration"
  },
  "dependencies": {
    "@abw/agent-core": "workspace:*",
    "@abw/db": "workspace:*",
    "@abw/project-types": "workspace:*",
    "@abw/providers": "workspace:*",
    "@abw/publish": "workspace:*",
    "@abw/security": "workspace:*",
    "@abw/shared": "workspace:*",
    "@abw/site-data": "workspace:*",
    "@abw/verify": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9",
    "@fastify/sensible": "^5.6.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sparticuz/chromium": "^131.0.1",
    "@supabase/supabase-js": "^2.103.3",
    "archiver": "^7.0.1",
    "css-tree": "^3.0.1",
    "drizzle-orm": "^0.31.0",
    "epub-gen-memory": "^1.1.2",
    "esbuild": "^0.21.5",
    "fastify": "^4.27.0",
    "file-type": "^19",
    "fluent-ffmpeg": "^2.1.3",
    "parse5": "^7.3.0",
    "pino": "^9.1.0",
    "postgres": "^3.4.4",
    "puppeteer-core": "^23.11.1",
    "replicate": "^1.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20.12.12",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
