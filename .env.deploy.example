# .env.deploy.example — Copy to .env.deploy (gitignored) and fill in your values.
# Run: node scripts/setup-deployment.mjs

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-api-settings

CF_ACCOUNT_ID=your-32-char-hex-account-id
CF_API_TOKEN=your-cloudflare-api-token

# Optional — Railway URL for the API backend
RAILWAY_API_URL=https://your-app-name.up.railway.app
